// Spara till fil
const fs = require('fs')
const path = require('path')
const outputPath = path.join(__dirname, '..', 'briefings', 'test-briefing.html')
fs.mkdirSync(path.dirname(outputPath), { recursive: true })
fs.writeFileSync(outputPath, html)

console.log('\n✅ Briefing genererad!')
